# ASI1 API (required). See: https://innovationlab.fetch.ai/resources/docs/asione/asi-one-quickstart
ASI_API_KEY=

# Agentverse API (required for registration). See: https://innovationlab.fetch.ai/resources/docs/agentverse/agentverse-api-key
ILABS_AGENTVERSE_API_KEY=

# Optional; must match your agent identity if you set one elsewhere (default in code: av-deploy-example)
AGENT_SEED_PHRASE=
