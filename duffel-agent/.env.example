# --- Agent (uAgents) — agent.py ---
AGENT_NAME=DuffelFlightsAgent
AGENT_PORT=8030
AGENTVERSE_URL=https://agentverse.ai
AGENT_SEED=Duffel_agent_flights_seed_live_1

# --- OpenAI — tools/openai_client.py ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Duffel & FX — tools/duffel_tools.py ---
DUFFEL_TOKEN=
FREECURRENCYAPI_KEY=
FET_USD_PRICE=

# --- Fetch chain — tools/fet_payments.py ---
FET_LCD_URL=https://rest-dorado.fetch.ai
FET_DENOM=afet
FET_DENOM_SCALE=
FET_VERIFY_ATTEMPTS=5
FET_VERIFY_DELAY_SEC=2.0

# --- Skyfire — tools/skyfire.py ---
SKYFIRE_ENV=qa
SELLER_ACCOUNT_ID=
JWT_AUDIENCE=
SELLER_SERVICE_ID=
SELLER_SKYFIRE_API_KEY=
SKYFIRE_API_KEY=
JWKS_URL=
JWT_ISSUER=
SKYFIRE_TOKENS_API_URL=

# --- SMTP (optional) — tools/duffel_tools.py, protocols/payment_proto.py ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Duffel Flights

# --- Payments — protocols/payment_proto.py ---
SELLER_RECIPIENT=
FIXED_FET_AMOUNT=0.001
FIXED_USD_AMOUNT=0.001

# --- Session DB — state_store.py ---
SESSION_DB_PATH=./state/sessions.db

