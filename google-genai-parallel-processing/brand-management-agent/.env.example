# OpenAI API key for DALL·E image generation (agent.py)
OPENAI_API_KEY=your_value_here

# Agentverse API token for external storage (uploading generated assets)
AGENTVERSE_API_KEY=your_value_here

# ASI One API key for asi1-mini chat completions (brand/tagline/synthesis)
ASI1_API_KEY=your_value_here

# Agentverse base URL for storage (optional; defaults to https://agentverse.ai)
AGENTVERSE_URL=your_value_here
